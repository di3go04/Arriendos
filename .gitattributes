# Auto detect text files and perform LF normalization
* text=auto

# Source files - enforce LF line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.mjs text eol=lf

# Ensure JSON files are always treated as UTF-8
*.json linguist-detectable
*.json working-tree-encoding=UTF-8

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text