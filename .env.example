# =====================================
# 🏠 RentNow - Variables de Entorno
# =====================================
# Copia este archivo a .env.local y completa los valores

# =====================================
# 🗄️ Supabase (Requerido)
# =====================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Requerido para módulo auth-enterprise (lockout, dispositivos)
SUPABASE_SERVICE_ROLE_KEY=

# =====================================
# 🤖 Google Gemini AI (Opcional)
# Para generación de contratos y predicción de morosidad
# Obtén tu API key en: https://aistudio.google.com/apikey
# =====================================
GEMINI_API_KEY=

# =====================================
# 📧 Resend (Opcional - para emails)
# =====================================
RESEND_API_KEY=

# =====================================
# 💳 Mercado Pago Checkout PRO (RECOMENDADO)
# El sistema de pagos principal de RentNow.
# No requiere Client ID ni Client Secret, solo el Access Token.
#
# Cómo obtener tu Access Token:
# 1. Ve a https://www.mercadopago.com.ar/developers/panel/app
# 2. Crea una aplicación o selecciona una existente
# 3. En "Credenciales", copia el "Access Token" (empieza con APP_USR- o TEST-)
# 4. Para pruebas usa las credenciales de Sandbox (TEST-)
# 5. Configura el webhook en el panel de Mercado Pago
#    URL: https://tudominio.com/api/payments/webhook
#    Eventos: payment
# =====================================
# Access Token (backend) — panel Mercado Pago → Credenciales (TEST-... o APP_USR-...)
MP_ACCESS_TOKEN=TEST_replace_with_your_mp_access_token
# Public Key (frontend Checkout API / Bricks) — misma pantalla de credenciales
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Secreto para validar webhooks (opcional pero recomendado en producción)
MP_WEBHOOK_SECRET=tu_webhook_secret_opcional

# OAuth (opcional) — solo si no usas Access Token directo del panel
# POST https://api.mercadopago.com/oauth/token
MP_OAUTH_TOKEN_URL=https://api.mercadopago.com/oauth/token
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# =====================================
# 💳 Stripe — Pagos internacionales USD (White-Label)
# El comprador solo pega sus llaves; sk_test_ (dev) o sk_live_ (prod) sin cambiar código.
# Dashboard: https://dashboard.stripe.com/apikeys
# Webhooks:  https://dashboard.stripe.com/webhooks → /api/webhooks/stripe
# Local:     stripe listen --forward-to localhost:3000/api/webhooks/stripe
# =====================================
STRIPE_SECRET_KEY=sk_replace_with_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_replace_with_your_publishable_key
# URL pública del sitio (success/cancel de Checkout)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Price IDs opcionales (si ya creaste productos en Stripe)
STRIPE_PRICE_PROFESIONAL=price_xxxxxxxx
STRIPE_PRICE_EMPRESA=price_xxxxxxxx

# =====================================
# 💳 Otros (Opcional - backup)
# =====================================
# PayPal
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# =====================================
# 🌐 App
# =====================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# VAPID Keys para Push Notifications (generar con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@email.com

# =====================================
# 📊 Analytics (PostHog - opcional)
# =====================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =====================================
# 📱 WhatsApp — Baileys (gratis, sin AiSensy)
# Terminal 1: npm run dev  |  Terminal 2: npm run whatsapp:bridge
# Producción: despliega scripts/whatsapp-bridge.mjs en un VPS y pon su URL aquí
# =====================================
WHATSAPP_BRIDGE_URL=http://127.0.0.1:3001
WHATSAPP_BRIDGE_PORT=3001
WHATSAPP_BRIDGE_SECRET=

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
