# ============================================================
# RentNow — Variables de Entorno (TODAS las integraciones)
# ============================================================
# Copia este archivo como .env.local y completa tus propias claves.
# NUNCA subas .env.local al repositorio. Contiene secretos reales.
#
# Instrucciones para obtener cada clave:
# - Supabase: https://supabase.com/dashboard → Project Settings → API
# - Stripe: https://dashboard.stripe.com/apikeys
# - Mercado Pago: https://www.mercadopago.com.pe/developers/panel
# - PayPal: https://developer.paypal.com/dashboard
# - Gemini AI: https://aistudio.google.com/app/apikey
# - Resend: https://resend.com/api-keys
# ============================================================

# ---- Supabase (obligatorio) ----
# Crear proyecto gratis en https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Auth (NextAuth) ----
# Generar con: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---- Demo Mode (opcional) ----
# En desarrollo: DEMO_MODE=true permite login con demo@rentnow.app / Demo123!
# En producción: DEMO_MODE=false o elimina esta variable
DEMO_MODE=false
# Flag público para que el frontend detecte modo demo
NEXT_PUBLIC_DEMO_MODE=false

# ---- Stripe (pagos SaaS + REaaS) ----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_REAS=

# ---- Mercado Pago (pagos LATAM) ----
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=

# ---- PayPal (suscripciones SaaS) ----
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_PROFESIONAL_PLAN_ID=
PAYPAL_EMPRESA_PLAN_ID=
PAYPAL_WEBHOOK_ID=

# ---- Google Gemini AI (contratos + predicción + marketing) ----
GEMINI_API_KEY=

# ---- Resend (transaccional email) ----
RESEND_API_KEY=

# ---- WhatsApp Baileys Bridge ----
WHATSAPP_BRIDGE_URL=http://127.0.0.1:3001
WHATSAPP_BRIDGE_SECRET=

# ---- Open Banking (Belvo) ----
BELVO_API_URL=https://api.belvo.com
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
BELVO_WEBHOOK_SECRET=

# ---- Twilio (Voice Agents IA + SMS) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Voiceflow (IA conversacional) ----
VOICEFLOW_API_KEY=
VOICEFLOW_AGENT_ID=

# ---- Map Provider (mapa interactivo en landing) ----
# Por defecto usa OpenStreetMap (gratis, sin token).
# Para usar Mapbox: descomenta y asigna NEXT_PUBLIC_MAP_PROVIDER=mapbox y NEXT_PUBLIC_MAPBOX_TOKEN
NEXT_PUBLIC_MAP_PROVIDER=osm
# Obtén un token público gratuito en https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ---- PostHog (analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Web Push (notificaciones PWA) ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Upstash Redis (rate limiting) ----
# Opcional. Sin esto, rate limiting usa memoria local.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
